        {
          "event": "Visit of Wise Men",
          "zadok_year": 4005,
          "gregorian_year": 1,
          "description": "Magi visited bearing gifts; Jesus presented as King to nations (Matthew 2:1-12)"
        },
        {
          "event": "Circumcision",
          "zadok_year": 4006,
          "gregorian_year": 2,
          "description": "Circumcised on eighth day; named Jesus (Luke 2:21)"
        },
        {
          "event": "Presentation in Temple",
          "zadok_year": 4006,
          "gregorian_year": 2,
          "description": "Presented as firstborn; recognized as Light of Gentiles (Luke 2:22-35)"
        },
        {
          "event": "Flight to Egypt",
          "zadok_year": 4006,
          "gregorian_year": 2,
          "description": "Family fled to Egypt to escape Herod's massacre (Matthew 2:13-15, Hosea 11:1)"
        },
        {
          "event": "Childhood in Nazareth",
          "zadok_year": 4007,
          "gregorian_year": 3,
          "description": "Grew up in Nazareth; trained in carpenter's trade (Matthew 2:19-23, Luke 2:39-40, 52)"
        },
        {
          "event": "Visit to Temple at Age 12",
          "zadok_year": 4017,
          "gregorian_year": 13,
          "description": "Found in Temple discussing with teachers; demonstrated wisdom (Luke 2:41-50)"
        },
        {
          "event": "Baptism by John",
          "zadok_year": 4031,
          "gregorian_year": 27,
          "description": "Baptized in Jordan; Spirit descended as dove; Father's voice confirmed (Matthew 3:13-17, Mark 1:9-11, Luke 3:21-22)"
        },
        {
          "event": "Temptation in Wilderness",
          "zadok_year": 4031,
          "gregorian_year": 27,
          "description": "Tempted by Satan for 40 days; overcome through God's word (Matthew 4:1-11, Mark 1:12-13, Luke 4:1-13)"
        },
        {
          "event": "Call of First Disciples",
          "zadok_year": 4031,
          "gregorian_year": 27,
          "description": "Called Simon Peter, Andrew, James, John as disciples (John 1:35-51)"
        },
        {
          "event": "Ministry Begins",
          "zadok_year": 4031,
          "gregorian_year": 27,
          "description": "Began public ministry with signs and teaching; proclaimed Kingdom (John 2-4)"
        },
        {
          "event": "Sermon on the Mount",
          "zadok_year": 4032,
          "gregorian_year": 28,
          "description": "Preached blessings and teachings of Kingdom (Matthew 5-7)"
        },
        {
          "event": "Miracles and Healings",
          "zadok_year": 4032,
          "gregorian_year": 28,
          "description": "Cast out demons, healed sick, raised dead, calmed storms (Matthew 8-9, Mark 1-5, Luke 5-9)"
        },
        {
          "event": "Choosing the Twelve",
          "zadok_year": 4032,
          "gregorian_year": 28,
          "description": "Selected 12 apostles as foundation of Church (Matthew 10:1-4, Mark 3:13-19, Luke 6:12-16)"
        },
        {
          "event": "Transfiguration",
          "zadok_year": 4033,
          "gregorian_year": 29,
          "description": "Revealed glory before Peter, James, John; Law and Prophets testified (Matthew 17:1-8, Mark 9:2-8, Luke 9:28-36)"
        },
        {
          "event": "Teaching on Kingdom",
          "zadok_year": 4033,
          "gregorian_year": 29,
          "description": "Taught in parables about Kingdom; ultimate authority revealed (Matthew 13, 18-25, Mark 4, 10-14, Luke 8, 15-18)"
        },
        {
          "event": "Triumphal Entry",
          "zadok_year": 4034,
          "gregorian_year": 30,
          "description": "Entered Jerusalem on donkey; hailed as Messiah (Matthew 21:1-11, Mark 11:1-11, Luke 19:28-40, John 12:12-15, Zechariah 9:9)"
        },
        {
          "event": "Cleansing of Temple",
          "zadok_year": 4034,
          "gregorian_year": 30,
          "description": "Overturned tables of money changers; demonstrated authority (Matthew 21:12-17, Mark 11:15-19, Luke 19:45-48)"
        },
        {
          "event": "Last Supper",
          "zadok_year": 4034,
          "gregorian_year": 30,
          "description": "Instituted covenant meal; broke bread and cup; 'This is my body, this is my blood' (Matthew 26:17-30, Mark 14:12-26, Luke 22:7-23, 1 Corinthians 11:23-26)"
        },
        {
          "event": "Gethsemane Prayer",
          "zadok_year": 4034,
          "gregorian_year": 30,
          "description": "Prayed 'Not my will but yours be done'; sweated drops of blood (Matthew 26:36-46, Mark 14:32-42, Luke 22:39-46)"
        },
        {
          "event": "Betrayal and Arrest",
          "zadok_year": 4034,
          "gregorian_year": 30,
          "description": "Betrayed by Judas; arrested by officers of Sanhedrin (Matthew 26:47-56, Mark 14:43-52, Luke 22:47-53, John 18:2-12)"
        },
        {
          "event": "Trial Before Sanhedrin",
          "zadok_year": 4034,
          "gregorian_year": 30,
          "description": "Questioned about being Messiah; condemned for blasphemy (Matthew 26:57-68, Mark 14:53-65, Luke 22:54-71, John 18:12-27)"
        },
        {
          "event": "Trial Before Pilate",
          "zadok_year": 4034,
          "gregorian_year": 30,
          "description": "Brought before Roman governor; accused of sedition; Pilate found no fault (Matthew 27:1-26, Mark 15:1-15, Luke 23:1-25, John 18:28-19:16)"
        },
        {
          "event": "Scourging and Mocking",
          "zadok_year": 4034,
          "gregorian_year": 30,
          "description": "Beaten by Roman soldiers; crowned with thorns; mocked as King (Matthew 27:26-31, Mark 15:15-20, John 19:1-5, Isaiah 50:6, 52:14)"
        },
        {
          "event": "Crucifixion",
          "zadok_year": 4034,
          "gregorian_year": 30,
          "description": "Crucified at Golgotha between two thieves; darkness over land; veil torn (Matthew 27:32-56, Mark 15:21-41, Luke 23:26-49, John 19:17-37, Psalm 22, Isaiah 53)"
        },
        {
          "event": "Pierced Side",
          "zadok_year": 4034,
          "gregorian_year": 30,
          "description": "Side pierced by soldier's spear; blood and water flowed (John 19:34, Zechariah 12:10)"
        },
        {
          "event": "Burial in Joseph's Tomb",
          "zadok_year": 4034,
          "gregorian_year": 30,
          "description": "Buried in new tomb of Joseph of Arimathea; stone sealed (Matthew 27:57-66, Mark 15:42-47, Luke 23:50-56, John 19:38-42, Isaiah 53:9)"
        },
        {
          "event": "Resurrection",
          "zadok_year": 4034,
          "gregorian_year": 30,
          "description": "Rose on the third day; death conquered; firstfruits of resurrection (Matthew 28:1-10, Mark 16:1-8, Luke 24:1-12, John 20:1-18, 1 Corinthians 15:3-8)"
        },
        {
