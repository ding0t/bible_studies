---
import BaseLayout from '../layouts/BaseLayout.astro';
import TimelineComponent from '../components/TimelineComponent.jsx';
import { getCollection } from 'astro:content';

// Load all studies and filter for timeline events (those with a year)
const allStudies = await getCollection('studies');
const timelineEvents = allStudies
  .filter(study => study.data.year && !study.data.draft)
  .map(study => ({
    id: study.id,
    slug: study.slug,
    year: study.data.year,
    title: study.data.title,
    description: study.data.description || '',
    category: study.data.category || 'other',
    tags: study.data.tags || []
  }))
  .sort((a, b) => a.year - b.year);
---

<BaseLayout title="Timeline">
  <div style="max-width: 1200px; margin: 0 auto;">
    <section style="margin-bottom: 2rem;">
      <p style="font-size: 1.0625rem; color: #475569; line-height: 1.8;">
        Welcome to the interactive prophetic timeline. This tool allows you to explore 
        key events in biblical history and prophecy, from the Old Testament era through 
        modern times. Zoom in for details or pan across to see the bigger picture.
      </p>
    </section>

    <TimelineComponent client:load events={timelineEvents} />

    <section style="margin-top: 3rem; padding: 1.5rem; background: white; border-radius: 0.75rem; border-left: 4px solid #3b82f6;">
      <h2 style="color: #1e293b; margin-bottom: 1rem;">About This Timeline</h2>
      <p style="color: #475569; margin-bottom: 0.75rem;">
        This interactive timeline visualizes key events in biblical prophecy and history. 
        Each point represents a significant moment that correlates with scriptural prophecy 
        or fulfillment.
      </p>
      <p style="color: #475569;">
        Use the zoom controls to get different perspectives on the timeline, and click any 
        event to read its narrative and significance.
      </p>
    </section>

    <section style="margin-top: 3rem; padding: 1.5rem; background: white; border-radius: 0.75rem; border-left: 4px solid #10b981;">
      <h2 style="color: #1e293b; margin-bottom: 1rem;">Biblical Genealogy</h2>
      <p style="color: #475569; margin-bottom: 1.5rem;">
        Explore the genealogical lineages from Adam through Jesus Christ. Visualize family trees, 
        lifespans across both Gregorian and Zadok calendars, discover Hebrew etymology, and trace 
        the lineage of Jesus through biblical history.
      </p>
      <a href="/genealogy-viewer/" style="display: inline-block; padding: 0.75rem 1.5rem; background: #10b981; color: white; text-decoration: none; border-radius: 0.5rem; font-weight: 500; transition: background 0.3s;">
        View Genealogy Viewer →
      </a>
    </section>
  </div>
</BaseLayout>
