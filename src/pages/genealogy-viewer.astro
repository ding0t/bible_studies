---
import GenealogyViewer from '../components/GenealogyViewer';
import BaseLayout from '../layouts/BaseLayout.jsx';

const title = 'Genealogy Viewer';
const description = 'Interactive biblical genealogy explorer with multiple views - family tree, timelines, lineage paths, and who-was-alive queries';
---

<BaseLayout title={title}>
  <main>
    <h1>{title}</h1>
    <p>{description}</p>
    
    <div class="genealogy-container">
      <GenealogyViewer client:load />
    </div>
  </main>
</BaseLayout>

<style>
  main {
    max-width: 1400px;
    margin: 0 auto;
    padding: 2rem 1rem;
  }

  .genealogy-container {
    margin: 2rem 0;
  }

  /* Responsive styling for genealogy viewer */
  @media (max-width: 1024px) {
    .genealogy-container {
      overflow-x: auto;
    }
  }
</style>
