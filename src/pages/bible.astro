---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.jsx';

// Get all commentaries
const commentaries = await getCollection('studies');
const bibleCommentaries = commentaries
  .filter(item => item.id.includes('bible/commentaries'))
  .filter(item => !item.data.draft)
  .sort((a, b) => a.data.title.localeCompare(b.data.title));

// Group commentaries by book
const grouped = bibleCommentaries.reduce((acc, item) => {
  const bookMatch = item.data.title.match(/^(\d+\s+)?(.+)$/);
  const book = bookMatch ? bookMatch[2] : item.data.title;
  if (!acc[book]) acc[book] = [];
  acc[book].push(item);
  return acc;
}, {} as Record<string, any[]>);

const bookOrder: Record<string, number> = {
  'Genesis': 1,
  'Exodus': 2,
  'Leviticus': 3,
  'Numbers': 4,
  'Deuteronomy': 5,
  'Joshua': 6,
  'Judges': 7,
  'Ruth': 8,
  '1 Samuel': 9,
  '2 Samuel': 10,
  '1 Kings': 11,
  '2 Kings': 12,
  '1 Chronicles': 13,
  '2 Chronicles': 14,
  'Ezra': 15,
  'Nehemiah': 16,
  'Esther': 17,
  'Job': 18,
  'Psalms': 19,
  'Proverbs': 20,
  'Ecclesiastes': 21,
  'Song of Solomon': 22,
  'Isaiah': 23,
  'Jeremiah': 24,
  'Lamentations': 25,
  'Ezekiel': 26,
  'Daniel': 27,
  'Hosea': 28,
  'Joel': 29,
  'Amos': 30,
  'Obadiah': 31,
  'Jonah': 32,
  'Micah': 33,
  'Nahum': 34,
  'Habakkuk': 35,
  'Zephaniah': 36,
  'Haggai': 37,
  'Zechariah': 38,
  'Malachi': 39,
  'Matthew': 40,
  'Mark': 41,
  'Luke': 42,
  'John': 43,
  'Acts': 44,
  'Romans': 45,
  '1 Corinthians': 46,
  '2 Corinthians': 47,
  'Galatians': 48,
  'Ephesians': 49,
  'Philippians': 50,
  'Colossians': 51,
  '1 Thessalonians': 52,
  '2 Thessalonians': 53,
  '1 Timothy': 54,
  '2 Timothy': 55,
  'Titus': 56,
  'Philemon': 57,
  'Hebrews': 58,
  'James': 59,
  '1 Peter': 60,
  '2 Peter': 61,
  '1 John': 62,
  '2 John': 63,
  '3 John': 64,
  'Jude': 65,
  'Revelation': 66,
};

const sortedBooks = Object.keys(grouped).sort((a, b) => {
  return (bookOrder[a] || 999) - (bookOrder[b] || 999);
});
---

<BaseLayout title="Bible Commentaries">
  <div style="max-width: 1000px; margin: 0 auto; padding: 2rem 1rem;">
    
    <!-- Header -->
    <div style="margin-bottom: 3rem; text-align: center;">
      <h1 style="color: #fcd34d; font-size: 2.5rem; margin-bottom: 1rem;">📖 Bible Commentaries</h1>
      <p style="color: #cbd5e1; font-size: 1.125rem;">
        Detailed studies and commentary on Scripture
      </p>
    </div>

    <!-- Commentaries by Book -->
    <div style="display: flex; flex-direction: column; gap: 2rem;">
      {sortedBooks.map((book) => {
        const items = grouped[book];
        return (
          <div key={book} style="border-left: 4px solid #fbbf24; padding-left: 1.5rem;">
            <h2 style="color: #fcd34d; font-size: 1.5rem; margin-bottom: 1rem;">
              {book}
            </h2>
            <div style="display: grid; gap: 1rem;">
              {items.map((commentary) => {
                const slug = commentary.id
                  .replace(/\.md$/, '')
                  .replace(/^studies\//, '');
                return (
                  <a 
                    href={`/studies/${slug}`}
                    key={commentary.id}
                    style={{
                      display: 'block',
                      padding: '1.5rem',
                      background: '#1e293b',
                      border: '1px solid #334155',
                      borderRadius: '0.5rem',
                      textDecoration: 'none',
                      color: 'inherit',
                      transition: 'all 0.2s',
                      cursor: 'pointer'
                    }}
                    onMouseOver={(e) => {
                      e.currentTarget.style.background = '#334155';
                      e.currentTarget.style.borderColor = '#fbbf24';
                      e.currentTarget.style.transform = 'translateX(4px)';
                    }}
                    onMouseOut={(e) => {
                      e.currentTarget.style.background = '#1e293b';
                      e.currentTarget.style.borderColor = '#334155';
                      e.currentTarget.style.transform = 'translateX(0)';
                    }}
                  >
                    <h3 style="color: #fbbf24; font-size: 1.1rem; margin-bottom: 0.5rem;">
                      {commentary.data.title}
                    </h3>
                    {commentary.data.description && (
                      <p style="color: #cbd5e1; font-size: 0.95rem;">
                        {commentary.data.description}
                      </p>
                    )}
                  </a>
                );
              })}
            </div>
          </div>
        );
      })}
    </div>

    <!-- Empty State -->
    {bibleCommentaries.length === 0 && (
      <div style="text-align: center; padding: 3rem; color: #94a3b8;">
        <p>No Bible commentaries published yet.</p>
        <p style="font-size: 0.875rem; margin-top: 1rem;">
          Commentaries will appear here as they are added to the content.
        </p>
      </div>
    )}

  </div>
</BaseLayout>
