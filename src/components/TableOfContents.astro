---
/**
 * Table of Contents component
 * Renders a navigable TOC from markdown headings
 */

interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  headings: Heading[];
  title?: string;
  minDepth?: number;
  maxDepth?: number;
}

const {
  headings,
  title = 'Contents',
  minDepth = 2,  // Start at h2 (h1 is usually the page title)
  maxDepth = 4   // Go down to h4
} = Astro.props;

// Filter headings by depth
const filteredHeadings = headings.filter(
  h => h.depth >= minDepth && h.depth <= maxDepth
);

// Don't render if no headings
if (filteredHeadings.length === 0) {
  return null;
}
---

<nav class="toc" aria-label="Table of contents">
  <details open>
    <summary class="toc-title">{title}</summary>
    <ul class="toc-list">
      {filteredHeadings.map((heading) => (
        <li
          class="toc-item"
          style={`--depth: ${heading.depth - minDepth}`}
        >
          <a
            href={`#${heading.slug}`}
            class="toc-link"
            data-heading={heading.slug}
          >
            {heading.text}
          </a>
        </li>
      ))}
    </ul>
  </details>
</nav>

<script>
  // Highlight current section in TOC based on scroll position
  function initTocHighlight() {
    const tocLinks = document.querySelectorAll('.toc-link[data-heading]');
    if (tocLinks.length === 0) return;

    // Get all heading IDs from TOC links
    const headingIds = Array.from(tocLinks).map(link => link.getAttribute('data-heading'));
    const headings = headingIds
      .map(id => document.getElementById(id))
      .filter(Boolean);

    if (headings.length === 0) return;

    let currentActive = null;

    const observer = new IntersectionObserver(
      (entries) => {
        // Find the first heading that's intersecting (visible)
        const visibleHeadings = entries
          .filter(entry => entry.isIntersecting)
          .map(entry => entry.target.id);

        // If we have visible headings, use the first one
        // Otherwise, find the heading that's above the viewport
        let activeId = null;

        if (visibleHeadings.length > 0) {
          activeId = visibleHeadings[0];
        } else {
          // Find the last heading that's above the viewport
          for (const heading of headings) {
            const rect = heading.getBoundingClientRect();
            if (rect.top < 150) {
              activeId = heading.id;
            }
          }
        }

        if (activeId && activeId !== currentActive) {
          // Remove active class from all links
          tocLinks.forEach(link => link.classList.remove('active'));

          // Add active class to current link
          const activeLink = document.querySelector(`.toc-link[data-heading="${activeId}"]`);
          if (activeLink) {
            activeLink.classList.add('active');
            currentActive = activeId;
          }
        }
      },
      {
        rootMargin: '-80px 0px -70% 0px',
        threshold: 0
      }
    );

    // Observe all headings
    headings.forEach(heading => observer.observe(heading));

    // Set initial active state
    const firstHeading = headings[0];
    if (firstHeading) {
      const firstLink = document.querySelector(`.toc-link[data-heading="${firstHeading.id}"]`);
      if (firstLink) {
        firstLink.classList.add('active');
        currentActive = firstHeading.id;
      }
    }
  }

  // Run on page load
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initTocHighlight);
  } else {
    initTocHighlight();
  }
</script>

<style>
  .toc {
    background: var(--color-card-bg, #f8fafc);
    border: 1px solid var(--color-border, #e2e8f0);
    border-radius: 0.5rem;
    padding: 1rem;
    margin-bottom: 2rem;
    font-size: 0.875rem;
  }

  .toc-title {
    font-weight: 600;
    color: var(--color-text, #1e293b);
    cursor: pointer;
    list-style: none;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-family: 'Outfit', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
  }

  .toc-title::before {
    content: '📑';
  }

  .toc-title::-webkit-details-marker {
    display: none;
  }

  details[open] .toc-title::after {
    content: '▼';
    font-size: 0.7rem;
    margin-left: auto;
    color: var(--color-text-subtle, #94a3b8);
  }

  details:not([open]) .toc-title::after {
    content: '▶';
    font-size: 0.7rem;
    margin-left: auto;
    color: var(--color-text-subtle, #94a3b8);
  }

  .toc-list {
    list-style: none;
    padding: 0;
    margin: 0.75rem 0 0 0;
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
  }

  .toc-item {
    display: block;
    padding-left: calc(var(--depth) * 0.75rem);
  }

  .toc-link {
    color: var(--color-text-subtle, #475569);
    text-decoration: none;
    display: block;
    padding: 0.25rem 0.5rem;
    border-radius: 0.25rem;
    transition: all 0.15s ease;
    border-left: 2px solid transparent;
    line-height: 1.4;
  }

  .toc-link:hover {
    color: var(--color-primary, #3b82f6);
    background: var(--color-card-hover, #e2e8f0);
    border-left-color: var(--color-primary, #3b82f6);
  }

  /* Active/current section highlight */
  .toc-link.active {
    color: var(--color-primary, #1d4ed8);
    font-weight: 600;
    background: color-mix(in srgb, var(--color-primary, #3b82f6) 15%, transparent);
    border-left-color: var(--color-primary, #3b82f6);
  }

  /* Sidebar context - when in .toc-sticky wrapper */
  :global(.toc-sticky) .toc {
    font-size: 0.8rem;
    padding: 0.875rem;
    margin-bottom: 0;
  }

  :global(.toc-sticky) .toc-title {
    font-size: 0.85rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--color-border, #e2e8f0);
    margin-bottom: 0.25rem;
  }

  :global(.toc-sticky) .toc-item {
    padding-left: calc(var(--depth) * 0.625rem);
    margin: 0.1rem 0;
  }

  :global(.toc-sticky) .toc-link {
    padding: 0.2rem 0.4rem;
    font-size: 0.8rem;
  }

  :global(.toc-sticky) .toc-list {
    margin-top: 0.5rem;
  }

  /* Custom scrollbar for sidebar TOC */
  :global(.toc-sticky) .toc-list::-webkit-scrollbar {
    width: 4px;
  }

  :global(.toc-sticky) .toc-list::-webkit-scrollbar-track {
    background: transparent;
  }

  :global(.toc-sticky) .toc-list::-webkit-scrollbar-thumb {
    background: var(--color-border-strong, #cbd5e1);
    border-radius: 2px;
  }

  /* Print styles */
  @media print {
    .toc {
      break-inside: avoid;
    }
  }
</style>
